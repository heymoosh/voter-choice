# Voter Choice — Environment Variables
# Copy this file to .env.local and fill in your keys.
# .env.local is gitignored and should never be committed.

# ---- Required ----------------------------------------------------------------

# Google Civic Information API
# Register at: https://console.cloud.google.com/
# Enable: "Civic Information API"
# Rate limit: 25,000 queries/day (free tier)
GOOGLE_CIVIC_API_KEY=your_google_civic_api_key_here

# Anthropic API — for candidate enrichment via web_search (Phase 3)
# and AI chat (Phase 5)
# Get your key at: https://console.anthropic.com/
ANTHROPIC_VOTER_API=your_anthropic_api_key_here

# ---- Optional ----------------------------------------------------------------

# OpenStates API — state legislative data (optional supplement to web_search)
# Register at: https://open.pluralpolicy.com/
OPENSTATES_API_KEY=your_openstates_api_key_here

# OpenFEC API — federal campaign finance data (optional supplement to web_search)
# Register at: https://api.open.fec.gov/developers/
OPENFEC_API_KEY=your_openfec_api_key_here
