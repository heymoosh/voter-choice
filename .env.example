ANTHROPIC_VOTER_API=
GOOGLE_CIVIC_API_KEY=
NEXT_PUBLIC_GOOGLE_PLACES_API_KEY=

# Optional durable/shared safeguards for production. Vercel KV and Upstash Redis
# expose these REST variables. If omitted, the app falls back to process-local
# counters suitable for local development only.
KV_REST_API_URL=
KV_REST_API_TOKEN=
# Alternative Upstash names are also supported:
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# Used only by scripts/provision-durable-safeguards.sh. Do not commit real
# values; pass them interactively or through your local shell.
UPSTASH_EMAIL=
UPSTASH_API_KEY=
UPSTASH_REGION=us-west-1
UPSTASH_PRIMARY_REGION=us-west-1
UPSTASH_DATABASE_NAME=voter-choice-launch-safeguards
USE_EXISTING_UPSTASH_REDIS=
