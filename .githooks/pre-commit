#!/usr/bin/env bash
# Lightweight optional pre-commit hook for AI Coding Practices repos.

set +e

if [ -x scripts/ai-worktree-intent.sh ]; then
  scripts/ai-worktree-intent.sh check
fi

if [ -x scripts/ai-mece-check.sh ]; then
  scripts/ai-mece-check.sh --strict
  rc=$?
  [ $rc -ne 0 ] && exit $rc
fi

if [ -x scripts/ai-qe-check.sh ]; then
  scripts/ai-qe-check.sh >/dev/null 2>&1
fi

if [ -x scripts/ai-verify.sh ]; then
  if [ "$(uname -s 2>/dev/null)" = "Darwin" ] && /usr/bin/arch -arm64 /usr/bin/true 2>/dev/null; then
    /usr/bin/arch -arm64 /bin/bash scripts/ai-verify.sh --staged
  else
    scripts/ai-verify.sh --staged
  fi
  rc=$?
  [ $rc -ne 0 ] && exit $rc
fi

exit 0
